<Page
    x:Class="BlendHub.Views.RestorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Views"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="36,24,36,36">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="BackupGrid.ColumnDefinitions[1].Width" Value="0" />
                        <Setter Target="BackupGrid.ColumnSpacing" Value="0" />
                        <Setter Target="ItemsExpander.(Grid.Column)" Value="0" />
                        <Setter Target="ItemsExpander.(Grid.Row)" Value="1" />
                        <Setter Target="HeaderGrid.ColumnDefinitions[1].Width" Value="0" />
                        <Setter Target="ActionPanel.(Grid.Row)" Value="1" />
                        <Setter Target="ActionPanel.(Grid.Column)" Value="0" />
                        <Setter Target="ActionPanel.HorizontalAlignment" Value="Left" />
                        <Setter Target="ActionPanel.Margin" Value="0,16,0,0" />
                        <Setter Target="StatusText.HorizontalAlignment" Value="Left" />
                        <Setter Target="VersionGrid.ColumnDefinitions[1].Width" Value="0" />
                        <Setter Target="VersionGrid.ColumnSpacing" Value="0" />
                        <Setter Target="RestoreDestinationExpander.(Grid.Column)" Value="0" />
                        <Setter Target="RestoreDestinationExpander.(Grid.Row)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Restore Blender Settings" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Recover your settings and addons from a previous backup." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
            
            <StackPanel x:Name="ActionPanel" Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusText" Text="" FontWeight="Medium" HorizontalAlignment="Right" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="RestoreProgressBar" Value="0" Maximum="100" Height="4" MinWidth="120" IsIndeterminate="False" Opacity="0" />
                </StackPanel>
                <Button x:Name="StartRestoreButton" Content="Start Restore" Style="{StaticResource AccentButtonStyle}" Padding="24,10" FontSize="14" FontWeight="Normal" Click="StartRestoreButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Stretch">
            <StackPanel Spacing="16">

                <!-- Backup Source + Items to Include -->
                <Grid x:Name="BackupGrid" ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Expander Grid.Row="0" Grid.Column="0" Header="Select Backup Location" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" IsExpanded="True">
                        <StackPanel Padding="20" Spacing="12" HorizontalAlignment="Stretch">
                            <TextBlock Text="Location where your backup files are stored." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12" HorizontalAlignment="Stretch">
                                <TextBox x:Name="BackupSourceTextBox" HorizontalAlignment="Stretch" TextChanged="BackupSourceTextBox_TextChanged" />
                                <Button Grid.Column="1" Content="Browse..." Height="32" Padding="20,0" Click="BrowseButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ItemsExpander" Grid.Row="0" Grid.Column="1" Header="Items to Include" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch" IsExpanded="True">
                        <StackPanel Padding="12" Spacing="4">
                            <ItemsControl x:Name="ItemsListView">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ConfigItemViewModel">
                                        <Grid MinWidth="140" Padding="4,2">
                                            <CheckBox Content="{x:Bind Name}" IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoItemsText" Text="Select a backup version to see available items." 
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="13" />
                        </StackPanel>
                    </Expander>
                </Grid>

                <!-- Version Selection -->
                <Grid x:Name="VersionGrid" ColumnSpacing="16" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Restore From -->
                    <Expander Grid.Row="0" Grid.Column="0" Header="Restore from" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" IsExpanded="True">
                        <StackPanel Padding="20" Spacing="12">
                            <TextBlock Text="Select the backup version to restore from." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <TextBlock Text="Version" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid Grid.Column="1" />
                                <ComboBox Grid.Column="2" x:Name="BackupVersionComboBox" MinWidth="200" SelectionChanged="BackupVersionComboBox_SelectionChanged" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Restore Destination -->
                    <Expander x:Name="RestoreDestinationExpander" Grid.Row="0" Grid.Column="1" Header="Restore Destination" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" IsExpanded="True">
                        <StackPanel Padding="20" Spacing="12">
                            <TextBlock Text="Choose the installed Blender version you want to restore these settings to." Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <TextBlock Text="Target Blender" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid Grid.Column="1" />
                                <ComboBox Grid.Column="2" x:Name="TargetVersionComboBox" MinWidth="200" DisplayMemberPath="DisplayName" SelectionChanged="TargetVersionComboBox_SelectionChanged" />
                            </Grid>
                        </StackPanel>
                    </Expander>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- InfoBars at bottom -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
            <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="True" Severity="Warning" Title="" Message="" />
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" IsClosable="True" Severity="Error" Title="" Message="" />
            <InfoBar x:Name="SuccessInfoBar" IsOpen="False" IsClosable="True" Severity="Success" Title="Restore Complete" Message="" />
        </StackPanel>

    </Grid>
</Page>
