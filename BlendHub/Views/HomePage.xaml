<Page
    x:Class="BlendHub.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:services="using:BlendHub.Services"
    xmlns:custom="using:BlendHub.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="UpdateBadgeBackgroundBrush" Color="#C23B22" />
                    <SolidColorBrush x:Key="UpdateBadgeBorderBrush" Color="#9E3118" />
                    <SolidColorBrush x:Key="UpdateBadgeForegroundBrush" Color="#FFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="UpdateBadgeBackgroundBrush" Color="#E7833A" />
                    <SolidColorBrush x:Key="UpdateBadgeBorderBrush" Color="#F4A261" />
                    <SolidColorBrush x:Key="UpdateBadgeForegroundBrush" Color="#1A0602" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="36,24,36,36">
            <StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock
                        Text="Version 1.0"
                        FontSize="16"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="BlendHub"
                        Style="{StaticResource TitleLargeTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        AutomationProperties.HeadingLevel="Level1" />
                </StackPanel>

                <custom:HorizontalScrollContainer Margin="0,32,0,0">
                    <custom:HorizontalScrollContainer.Source>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Grid Width="232" 
                                  Height="120"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="8">
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Click="CreateBackupCard_Click">
                                    <Grid Padding="16,14,16,14" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <FontIcon Glyph="&#xE74E;" 
                                                  FontSize="28" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top" />
                                        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                            <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       Text="Create Backup" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       TextWrapping="Wrap" 
                                                       Text="Save your Blender preferences securely." />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                            <Grid Width="232" 
                                  Height="120"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="8">
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Click="RestoreCard_Click">
                                    <Grid Padding="16,14,16,14" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <FontIcon Glyph="&#xE72C;" 
                                                  FontSize="28" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top" />
                                        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                            <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       Text="Restore Data" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       TextWrapping="Wrap" 
                                                       Text="Recover config from a previous backup." />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                            <Grid Width="232" 
                                  Height="120"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="8">
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Click="SyncCard_Click">
                                    <Grid Padding="16,14,16,14" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <FontIcon Glyph="&#xE895;" 
                                                  FontSize="28" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top" />
                                        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                            <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       Text="Sync Versions" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       TextWrapping="Wrap" 
                                                       Text="Synchronize settings across versions." />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                            <Grid Width="232" 
                                  Height="120"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="8">
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Click="ProjectsCard_Click">
                                    <Grid Padding="16,14,16,14" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <FontIcon Glyph="&#xE8B7;" 
                                                  FontSize="28" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top" />
                                        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                            <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       Text="Projects" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       TextWrapping="Wrap" 
                                                       Text="Manage your Blender projects natively." />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                            <Grid Width="232" 
                                  Height="120"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                  BorderThickness="1" 
                                  CornerRadius="8">
                                <Button Style="{StaticResource SubtleButtonStyle}"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Padding="0"
                                        Click="InstallCard_Click">
                                    <Grid Padding="16,14,16,14" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <FontIcon Glyph="&#xE8A5;" 
                                                  FontSize="28" 
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                                                  HorizontalAlignment="Left" 
                                                  VerticalAlignment="Top" />
                                        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                            <TextBlock Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" 
                                                       Text="Install Blender" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                                       Style="{StaticResource CaptionTextBlockStyle}" 
                                                       TextWrapping="Wrap" 
                                                       Text="Download and install different Blender versions." />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </custom:HorizontalScrollContainer.Source>
                </custom:HorizontalScrollContainer>

                <Border
                    Height="1"
                    Margin="0,36,0,16"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="Installed Blender versions"
                                   FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   AutomationProperties.HeadingLevel="Level2" />
                        <Button Grid.Column="1"
                                Click="RefreshButton_Click"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontSize="16" />
                        </Button>
                    </Grid>

                    <GridView x:Name="VersionsGridView"
                              SelectionMode="None"
                              HorizontalAlignment="Stretch"
                              Margin="-8,0">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <controls:ItemsWrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Height" Value="Auto"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="services:BlenderVersionInfo">
                                <Border Margin="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Source="/Assets/blender_logo.png" Width="24" Height="24"
                                               VerticalAlignment="Top" Margin="0,2,16,0" Stretch="Uniform"/>
                                        <Grid Grid.Column="1" MinHeight="120">
                                        <StackPanel Spacing="8" VerticalAlignment="Top">
                                            <!-- Version Header -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind DisplayName}" FontSize="16" FontWeight="SemiBold"/>
                                                <Border Visibility="{x:Bind IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                                                        Padding="6,2"
                                                        Background="{ThemeResource UpdateBadgeBackgroundBrush}"
                                                        BorderBrush="{ThemeResource UpdateBadgeBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="UPDATE" FontSize="10" FontWeight="SemiBold" Foreground="{ThemeResource UpdateBadgeForegroundBrush}"/>
                                                </Border>
                                            </StackPanel>
                                                
                                                <!-- Build Type -->
                                                <TextBlock Text="Stable Official Build" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                
                                                <!-- Installation Path -->
                                                <TextBlock Text="{x:Bind ExecutablePath}" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTipService.ToolTip="{x:Bind ExecutablePath}"/>
                                                
                                                <!-- Separator -->
                                                <Border Height="1" 
                                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                                                        Margin="0,8,0,8"/>
                                                
                                                <!-- Action Buttons -->
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <Button Content="Open Blender"
                                                            IsEnabled="{x:Bind ExecutablePath, Converter={StaticResource StringToBoolConverter}}"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Padding="16,8" 
                                                            MinHeight="32"
                                                            Click="LaunchBlender_Click" />
                                                    <Button Content="Open Config Folder" 
                                                            Click="OpenSettings_Click"
                                                            Style="{StaticResource DefaultButtonStyle}"
                                                            Padding="16,8"
                                                            MinHeight="32" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
