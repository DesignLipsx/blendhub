<UserControl x:ConnectionId='1'
    x:Class="BlendHub.Controls.BlenderLaunchButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid VerticalAlignment="Center" ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button x:ConnectionId='2' x:Name="MainButton"
                Style="{StaticResource AccentButtonStyle}"
                                        
                CornerRadius="4,0,0,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon x:ConnectionId='5'                                         FontSize="14" />
                <TextBlock x:ConnectionId='6'                                   />
            </StackPanel>
        </Button>

        <Rectangle Grid.Column="1"
                   Width="1"
                   VerticalAlignment="Stretch"
                   Fill="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                   Opacity="0.10" />

        <Button x:ConnectionId='3' x:Name="ArrowButton"
                Grid.Column="2"
                Style="{StaticResource AccentButtonStyle}"
                Padding="12,0"
                VerticalAlignment="Stretch"
                CornerRadius="0,4,4,0">
            <FontIcon Glyph="&#xE70D;" FontSize="12" />
            <Button.Flyout>
                <MenuFlyout x:ConnectionId='4'                              Placement="Bottom" />
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>

