<Page x:ConnectionId='1'
    x:Class="BlendHub.Pages.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:custom="using:BlendHub.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="NoteTemplate">
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <FontIcon Grid.Column="0" Grid.RowSpan="2" Glyph="&#xF000;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Left" Margin="4,0,0,0" VerticalAlignment="Center" />
                    
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,4" />
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding CreatedAtString}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="2" Grid.RowSpan="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button x:ConnectionId='10'                        Tag="{Binding}" Style="{StaticResource SubtleButtonStyle}" Padding="6">
                            <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Button>
                        <Button x:ConnectionId='11'                          Tag="{Binding}" Style="{StaticResource SubtleButtonStyle}" Padding="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        
        <DataTemplate x:Key="TodoTemplate">
            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <CheckBox x:ConnectionId='6' Grid.Column="0" Grid.RowSpan="2" IsChecked="{Binding IsChecked, Mode=TwoWay}"                            Tag="{Binding Id}" 
                              HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Center" MinWidth="0" />
                    <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0" Spacing="8" Margin="0,0,0,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" VerticalAlignment="Center"
                                   TextDecorations="{Binding TextDecoration}" Foreground="{Binding TextColorBrush}" />
                        <Border Background="{Binding PriorityBackgroundColor}" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Visibility="{Binding PriorityVisibility}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE7C1;" FontSize="10" Foreground="{Binding PriorityIconColor}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PriorityText}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding PriorityTextColor}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding CreatedAtString}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="2" Grid.RowSpan="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button x:ConnectionId='7'                        Tag="{Binding}" Style="{StaticResource SubtleButtonStyle}" Padding="6">
                            <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Button>
                        <Button x:ConnectionId='8'                          Tag="{Binding}" Style="{StaticResource SubtleButtonStyle}" Padding="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="ItemsPanelTemplate">
            <StackPanel Spacing="6" />
        </ItemsPanelTemplate>

        <local:ProjectItemTemplateSelector x:Key="ItemSelector" 
                                           NoteTemplate="{StaticResource NoteTemplate}" 
                                           TodoTemplate="{StaticResource TodoTemplate}" />

        <DataTemplate x:Key="FolderTemplate"                                   >
            <controls:SettingsCard x:ConnectionId='3' 
                                       
                                                    
                IsClickEnabled="True"
                                        
                                   >
                <controls:SettingsCard.HeaderIcon>
                    <BitmapIcon x:ConnectionId='4'                              ShowAsMonochrome="False" />
                </controls:SettingsCard.HeaderIcon>
            </controls:SettingsCard>
        </DataTemplate>
    </Page.Resources>

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,24,24,8">
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                <Button x:ConnectionId='32'                          
                        Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" />
                </Button>
                <StackPanel Spacing="4">
                    <TextBlock x:ConnectionId='33' x:Name="ProjectTitle" Text="" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:ConnectionId='34' x:Name="ProjectPath" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:ConnectionId='28' x:Name="EditBtn"                           ToolTipService.ToolTip="Edit Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                        <TextBlock Text="Edit" />
                    </StackPanel>
                </Button>
                <Button x:ConnectionId='29' x:Name="DeleteBtn"                             ToolTipService.ToolTip="Delete Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        <TextBlock Text="Delete" />
                    </StackPanel>
                </Button>
                <AppBarSeparator Margin="4,0,4,0" />
                <Button x:ConnectionId='30' x:Name="OpenFolderBtn"                         >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xED25;" FontSize="14" />
                        <TextBlock Text="Open Folder" />
                    </StackPanel>
                </Button>
                <custom:BlenderLaunchButton x:ConnectionId='31' x:Name="OpenBlendBtn" 
                                                                                     
                                            Text="Open Project" 
                                            IconGlyph="&#xE8E5;" />
            </StackPanel>
        </Grid>

        <!-- Quick Stats -->
        <Grid Grid.Row="1" Margin="24,0,24,0" ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Blender Version" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='27' x:Name="BlenderVersionText" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Blend File" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='26' x:Name="BlendFileText" FontSize="13" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Created" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='25' x:Name="CreatedAtText" FontSize="13" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Last Modified" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='24' x:Name="ModifiedAtText" FontSize="13" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Project Size" FontSize="11" FontWeight="SemiBold" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:ConnectionId='23' x:Name="ProjectSizeText" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content with SelectorBar -->
        <Grid Grid.Row="2" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,0,24,0">
                <SelectorBar x:ConnectionId='14' x:Name="ContentSelectorBar" HorizontalAlignment="Left"                                                       >
                    <SelectorBarItem x:ConnectionId='20' x:Name="LocationsTab" Text="Project Locations" Icon="Folder" />
                    <SelectorBarItem x:ConnectionId='21' x:Name="NotesTab" Text="Notes &amp; Tasks" Icon="Edit" />
                    <SelectorBarItem x:ConnectionId='22' x:Name="FilesTab" Text="Project Files" Icon="Document" />
                </SelectorBar>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                    <Button x:ConnectionId='15' x:Name="RefreshLocationsBtn"                                Padding="12,6" ToolTipService.ToolTip="Scan for new folders">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            <TextBlock Text="Refresh" FontSize="13" />
                        </StackPanel>
                    </Button>
                    <DropDownButton x:ConnectionId='16' x:Name="AddNoteBtn" Visibility="Collapsed" Padding="12,6">
                        <DropDownButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                <TextBlock Text="Add Item" FontSize="13" />
                            </StackPanel>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:ConnectionId='18' Text="Add Note"                              Tag="Note" />
                                <MenuFlyoutItem x:ConnectionId='19' Text="Add Task"                              Tag="Todo" />
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                    <Button x:ConnectionId='17' x:Name="AddFileBtn" Visibility="Collapsed"                             Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="Add File" FontSize="13" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,16,24,24">
                <Frame x:ConnectionId='13' x:Name="ContentFrame" />
            </ScrollViewer>
        </Grid>

        <!-- Warning -->
        <InfoBar x:ConnectionId='12' x:Name="MissingProjectInfoBar" Grid.Row="2"
                 Margin="32,0,32,32" VerticalAlignment="Bottom"
                 IsOpen="False"
                 IsClosable="False"
                 Severity="Warning"
                 Title="Project Folder Missing"
                 Message="The project folder could not be found on disk. Some actions may not work." />
    </Grid>
</Page>

