<Page
    x:Class="BlendHub.Pages.ProjectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:custom="using:BlendHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Fixed Header Section -->
        <StackPanel Grid.Row="0" Spacing="16" Padding="24,24,24,8">
            <!-- Header -->
            <Grid>
                <StackPanel Spacing="8">
                    <TextBlock Text="Project Management" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>

                <Button x:ConnectionId='23' x:Name="CreateProjectBtn" 
                        Content="Create Project" 
                                                 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="24,10" 
                        FontSize="14" 
                        FontWeight="Normal"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Progress Bar -->
            <StackPanel x:ConnectionId='9' x:Name="CreatingProgressPanel" Visibility="Collapsed" 
                        Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ProgressBar Width="130" IsIndeterminate="True" ShowPaused="False" ShowError="False" />
                <TextBlock x:ConnectionId='22' x:Name="ProgressText" Text="Creating project..." VerticalAlignment="Center" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Feedback -->
            <InfoBar x:ConnectionId='10' x:Name="ProjectSuccessInfoBar"
                     IsOpen="False"
                     Severity="Success"
                     Title="Project Created">
                <InfoBar.ActionButton>
                    <Button x:ConnectionId='21' Content="Open Project"                           />
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Projects List Header with Search and Sort -->
            <StackPanel x:ConnectionId='11' x:Name="ProjectsListContainer" Spacing="8">
                <!-- Section Header with Search and Sort -->
                <Grid x:ConnectionId='12' x:Name="ProjectsHeaderGrid" Visibility="Visible" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left side: Search and Refresh -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <AutoSuggestBox x:ConnectionId='19' x:Name="SearchTextBox" 
                                       Grid.Column="0"
                                       Width="280"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       PlaceholderText="Search projects..."
                                       Padding="12,6,8,6"
                                                                       >
                            <AutoSuggestBox.QueryIcon>
                                <FontIcon Glyph="&#xE721;" FontSize="14" />
                            </AutoSuggestBox.QueryIcon>
                        </AutoSuggestBox>
                        
                        <Button x:ConnectionId='20' x:Name="RefreshProjectsButton" 
                                Grid.Column="1"
                                Style="{StaticResource DefaultButtonStyle}"
                                Width="32"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="0"
                                                                   
                                ToolTipService.ToolTip="Refresh Projects"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </Grid>
                    
                    <!-- Right side: Sort Menu -->
                    <Button x:ConnectionId='13' x:Name="SortButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTipService.ToolTip="Sort">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8CB;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:ConnectionId='14' x:Name="SortButtonText" Text="Date Created (Newest)" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:ConnectionId='15' x:Name="SortDateDescItem" 
                                                     Text="Date Created (Newest)" 
                                                     GroupName="SortGroup"
                                                     IsChecked="True"
                                                                               />
                                <RadioMenuFlyoutItem x:ConnectionId='16' x:Name="SortDateAscItem" 
                                                     Text="Date Created (Oldest)" 
                                                     GroupName="SortGroup"
                                                                               />
                                <RadioMenuFlyoutItem x:ConnectionId='17' x:Name="SortNameAscItem" 
                                                     Text="Name (A-Z)" 
                                                     GroupName="SortGroup"
                                                                               />
                                <RadioMenuFlyoutItem x:ConnectionId='18' x:Name="SortNameDescItem" 
                                                     Text="Name (Z-A)" 
                                                     GroupName="SortGroup"
                                                                               />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
                
                <!-- Separator -->
                <Border Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Scrollable Content Section -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <StackPanel>

                <!-- Drag and Drop Zone -->
                <Border x:ConnectionId='2' x:Name="DropZone"
                        AllowDrop="True"
                                                    
                                            
                        CornerRadius="8"
                        Padding="0"
                        MinHeight="180">
                    <Grid>
                        <Rectangle Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="2,2"
                                   RadiusX="8"
                                   RadiusY="8"
                                   Fill="Transparent"
                                   Margin="0"/>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Padding="40,0">
                            <FontIcon Glyph="&#xE8E5;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Drag and drop to add project"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Drop a folder containing .blend files here"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:ConnectionId='8' x:Name="BrowseProjectBtn"
                                                                  
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xED25;" FontSize="14"/>
                                    <TextBlock Text="Browse for project folder" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Projects List -->
                <ItemsControl x:ConnectionId='3' x:Name="ProjectsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                            >
                            <custom:ProjectCardView x:ConnectionId='7'                    />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No Search Results Message -->
                <StackPanel x:ConnectionId='4' x:Name="NoSearchResultsPanel" Spacing="16" Margin="0,40,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE94C;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No projects found matching your search." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Empty state -->
                <StackPanel x:ConnectionId='5' x:Name="NoProjectsPanel" Spacing="16" Margin="0,40,0,0" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7C3;" FontSize="64" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No projects yet. Create your first project by clicking 'Create Project' or drag a folder above." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

