<UserControl
    x:Class="BlendHub.Pages.DownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters">
    
    <UserControl.Resources>
        <converters:BytesToSizeConverter x:Key="BytesToSizeConverter" />
        <converters:PlatformConverter x:Key="PlatformConverter" />
    </UserControl.Resources>
    
    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinWidth="750" MaxWidth="800" Spacing="16">
        <!-- Header: Version -->
        <TextBlock x:ConnectionId='2' x:Name="DialogVersionText"
                   FontSize="16" 
                   FontWeight="SemiBold"/>

        <!-- Filters Row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Platform Filter -->
            <ComboBox x:ConnectionId='15' x:Name="DialogPlatformComboBox"
                      Grid.Column="0"
                      Width="160"
                                                                                >
                <ComboBoxItem Content="Windows x64" Tag="windows-x64" IsSelected="True"/>
                <ComboBoxItem Content="ARM64" Tag="windows-arm64"/>
                <ComboBoxItem Content="x86" Tag="windows32"/>
                <ComboBoxItem Content="All Platforms" Tag="all"/>
            </ComboBox>
            
            <!-- Type Filter -->
            <ComboBox x:ConnectionId='16' x:Name="DialogTypeComboBox"
                      Grid.Column="1"
                      Width="140"
                      Margin="12,0,0,0"
                                                                            >
                <ComboBoxItem Content="All Types" Tag="all" IsSelected="True"/>
                <ComboBoxItem Content="MSI" Tag=".msi"/>
                <ComboBoxItem Content="MSIX" Tag=".msix"/>
                <ComboBoxItem Content="ZIP" Tag=".zip"/>
            </ComboBox>

            <!-- View Download Page Button -->
            <Button x:ConnectionId='17' x:Name="DialogViewDownloadPage"
                    Grid.Column="3"
                                                        
                    Style="{StaticResource DefaultButtonStyle}"
                    Height="32"
                    Padding="12,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71B;" FontSize="12"/>
                    <TextBlock Text="View Download Page" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>
        <!-- Separator -->
        <Border Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Installers List with ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      MaxHeight="360"
                      Padding="0,0,0,0">
            <StackPanel>
                <ItemsControl x:ConnectionId='6' x:Name="DialogInstallersList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                     >
                            <Border x:ConnectionId='9' Margin="0,3" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6" 
                                    Padding="16,8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" 
                                                Orientation="Horizontal" 
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock x:ConnectionId='11'                          
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Width="240"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:ConnectionId='12'                                                                        
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Width="70"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run x:ConnectionId='13'                                                                           />
                                            <Run Text=" • "/>
                                            <Run x:ConnectionId='14'                            />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button x:ConnectionId='10' Grid.Column="1"
                                                                                 
                                                                  
                                            Style="{StaticResource AccentButtonStyle}"
                                            MinWidth="120"
                                            Height="28"
                                            Padding="12,0"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                            <TextBlock Text="Download" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No Installers Found Message -->
                <TextBlock x:ConnectionId='7' x:Name="DialogNoInstallersMessage"
                           Text="No installers found with selected filters."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"
                           Margin="20,40,20,40"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress Section -->
        <StackPanel x:ConnectionId='3' x:Name="DialogProgressPanel"
                    Spacing="6"
                    Visibility="Collapsed">
            <ProgressBar x:ConnectionId='4' x:Name="DialogProgressBar"
                         IsIndeterminate="False"
                         Value="0"
                         Maximum="100"/>
            <TextBlock x:ConnectionId='5' x:Name="DialogProgressText"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </StackPanel>
</UserControl>

