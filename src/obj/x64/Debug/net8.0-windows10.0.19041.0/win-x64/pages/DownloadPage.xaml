<Page
    x:Class="BlendHub.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BytesToSizeConverter x:Key="BytesToSizeConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="16" Padding="24,24,24,0">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Download" FontSize="28" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
            
            <Grid Padding="0">
                <Grid x:ConnectionId='15' x:Name="LoadingPanel" Visibility="Collapsed" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ProgressRing Grid.Column="0" Width="16" Height="16" IsActive="True"/>
                    <TextBlock x:ConnectionId='17' x:Name="LoadingText" Grid.Column="1" Text="Loading versions..." 
                               FontSize="12" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <InfoBar x:ConnectionId='16' x:Name="ErrorInfoBar"
                         IsOpen="False"
                         Title="Error"
                         Severity="Error" />
            </Grid>

            <StackPanel Spacing="8">
                <Grid Margin="0,0,0,0" ColumnDefinitions="Auto, *, Auto">
                    <!-- Left side: Search and Refresh -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <AutoSuggestBox x:ConnectionId='11' x:Name="SearchBox" 
                                       Grid.Column="0"
                                       Width="280"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       PlaceholderText="Search Blender versions..."
                                       Padding="12,6,8,6"
                                                                          >
                            <AutoSuggestBox.QueryIcon>
                                <FontIcon Glyph="&#xE721;" FontSize="14" />
                            </AutoSuggestBox.QueryIcon>
                        </AutoSuggestBox>
                        
                        <Button x:ConnectionId='12' x:Name="RefreshButton" 
                                Grid.Column="1"
                                Style="{StaticResource DefaultButtonStyle}"
                                Width="32"
                                Height="32"
                                Margin="12,0,0,0"
                                Padding="0"
                                                           
                                ToolTipService.ToolTip="Refresh"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <FontIcon x:ConnectionId='14' x:Name="RefreshButtonIcon" Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <ProgressRing x:ConnectionId='13' x:Name="RefreshProgressRing"
                                      Grid.Column="1"
                                      Width="20"
                                      Height="20"
                                      Margin="12,0,0,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"
                                      IsActive="True"/>
                    </Grid>
                    
                    <!-- Right side: Sort Menu -->
                    <Button x:ConnectionId='7' x:Name="SortButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTipService.ToolTip="Sort">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8CB;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:ConnectionId='8' x:Name="SortButtonText" Text="Version (Newest First)" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:ConnectionId='9' x:Name="SortNewestItem" 
                                                     Text="Version (Newest First)" 
                                                     GroupName="SortGroup"
                                                     IsChecked="True"
                                                                               />
                                <RadioMenuFlyoutItem x:ConnectionId='10' x:Name="SortOldestItem" 
                                                     Text="Version (Oldest First)" 
                                                     GroupName="SortGroup"
                                                                               />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <!-- Separator -->
                <Border Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
            </StackPanel>
        </StackPanel>

        <ListView x:ConnectionId='2' x:Name="VersionsListView"
                  Grid.Row="1"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch"
                  Padding="24,8,24,24">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Vertical" CacheLength="2"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            
            <ListView.ItemTemplate>
                <DataTemplate                                        >
                    <controls:SettingsCard x:ConnectionId='4' 
                        Margin="0,0,0,4"
                                                      
                                                          
                        Padding="16"
                        IsActionIconVisible="False"
                        IsClickEnabled="True"
                                                  
                                              >
                        <controls:SettingsCard.HeaderIcon>
                            <ImageIcon Source="/Assets/blender_logo.png"/>
                        </controls:SettingsCard.HeaderIcon>

                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock x:ConnectionId='5'                                     
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Button x:ConnectionId='6'                             
                                                          
                                    Style="{StaticResource AccentButtonStyle}"
                                    MinWidth="120"
                                    Height="32"
                                    VerticalAlignment="Center">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                        <TextBlock Text="Download"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </controls:SettingsCard>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

