<Page x:ConnectionId='1'
    x:Class="BlendHub.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BlendHub.Models"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.SettingsControls/SettingsExpander/SettingsExpander.xaml" />
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.SettingsControls/SettingsCard/SettingsCard.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <x:Double x:Key="SettingsCardSpacing">4</x:Double>

            <Style x:Key="SettingsSectionHeaderTextBlockStyle"
                   BasedOn="{StaticResource BodyStrongTextBlockStyle}"
                   TargetType="TextBlock">
                <Style.Setters>
                    <Setter Property="Margin" Value="1,16,0,6" />
                </Style.Setters>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:ConnectionId='2' x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <TextBlock x:ConnectionId='3'
            x:Name="PageHeader"
            Margin="24,24,24,0"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Settings" />
            
        <ScrollView
            Grid.Row="1"
            Padding="24,24,24,24"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Border>
                <StackPanel Spacing="{StaticResource SettingsCardSpacing}">
                
                <!-- Appearance & Behavior Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Appearance &amp; behavior" />

                <controls:SettingsCard Description="Choose which theme you want the app to use."
                                       Header="App Theme"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:ConnectionId='33' x:Name="ThemeComboBox" Width="200" VerticalAlignment="Center"                                                  >
                        <ComboBoxItem Content="Auto" Tag="Default" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </controls:SettingsCard>

                <controls:SettingsCard Description="Set the name that will be used for greetings throughout the app."
                                       Header="Username"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE77B;}">
                    <TextBox x:ConnectionId='32' x:Name="UserNameTextBox" Width="200" VerticalAlignment="Center"                                                                         />
                </controls:SettingsCard>

                <controls:SettingsCard Description="Choose which page should open when you start BlendHub."
                                       Header="Default Page"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE71D;}">
                    <ComboBox x:ConnectionId='31' x:Name="DefaultPageComboBox" Width="200" VerticalAlignment="Center"                                                        >
                        <ComboBoxItem Content="Home" Tag="home" />
                        <ComboBoxItem Content="Download" Tag="download" />
                        <ComboBoxItem Content="Backup" Tag="backup" />
                        <ComboBoxItem Content="Restore" Tag="restore" />
                        <ComboBoxItem Content="Sync" Tag="sync" />
                        <ComboBoxItem Content="Projects" Tag="project" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- General Settings Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="General" />
                
                <!-- Custom Blender Installations -->
                <controls:SettingsExpander x:ConnectionId='4' Header="Custom Blender Installations"
                                         Description="Add custom Blender executables to show on the Home page."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xE7B8;}"
                                         IsExpanded="False"
                                                                              >
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate                                      >
                            <controls:SettingsCard x:ConnectionId='26' CornerRadius="0" Margin="0,-1,0,0">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                    <TextBlock x:ConnectionId='27' Grid.Column="0" 
                                                                               
                                             TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" />
                                    <Button x:ConnectionId='28' Grid.Column="1" 
                                                                              
                                            Content="&#xE8DA;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            ToolTipService.ToolTip="Change Path"
                                            VerticalAlignment="Stretch"
                                                                   />
                                    <Button x:ConnectionId='29' Grid.Column="2" 
                                                                              
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                                                  
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard x:ConnectionId='30' IsClickEnabled="True"                                CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add Blender Executable" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- Backup and Restore Settings -->
                <controls:SettingsCard Description="The location where your Blender backup files will be saved and restored from."
                                       Header="Backup Location"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE838;}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock x:ConnectionId='23' x:Name="BackupLocationTextBox" 
                                 Grid.Column="0"
                                 VerticalAlignment="Center" 
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" />
                        <Button x:ConnectionId='24' Grid.Column="1"
                                                                   
                                Content="&#xE8DA;" 
                                FontFamily="Segoe Fluent Icons" 
                                ToolTipService.ToolTip="Browse Folder"
                                VerticalAlignment="Stretch" />
                    </Grid>
                </controls:SettingsCard>

                <!-- Default Project Folders Configuration -->
                <controls:SettingsExpander x:ConnectionId='5' Header="Default Project Folder Structure"
                                         Description="Configure the default folders created for new projects."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xE8B7;}"
                                         IsExpanded="False"
                                                                              >
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate                                  >
                            <controls:SettingsCard x:ConnectionId='18' CornerRadius="0" Margin="0,-1,0,0">
                                <controls:SettingsCard.Header>
                                    <TextBlock x:ConnectionId='19'                                    VerticalAlignment="Center" />
                                </controls:SettingsCard.Header>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBox x:ConnectionId='20' Grid.Column="0" 
                                                                                                                    
                                             PlaceholderText="Folder name" 
                                             VerticalAlignment="Center" Width="200"
                                                                                
                                                                                     />
                                    <Button x:ConnectionId='21' Grid.Column="1" 
                                                                       
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                                                  
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard x:ConnectionId='22' IsClickEnabled="True"                         CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add Folder" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- File Type Associations (Launchers) -->
                <controls:SettingsExpander x:ConnectionId='6' Header="Default File Launchers"
                                         Description="Set default programs for file types. New projects will automatically use these associations."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xE71D;}"
                                         IsExpanded="False"
                                                                         >
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate                                 >
                            <controls:SettingsCard x:ConnectionId='10' CornerRadius="0" Margin="0,-1,0,0">
                                <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="File type" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                                        <TextBox x:ConnectionId='11'                                                                             
                                                 PlaceholderText=".psd" 
                                                 VerticalAlignment="Center" Width="80"
                                                                                   
                                                                                        />
                                    </StackPanel>
                                </controls:SettingsCard.Header>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                    <TextBlock x:ConnectionId='12' Grid.Column="0" Text="Program path:" VerticalAlignment="Center" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"
                                                                                                                                                      />
                                    <TextBlock x:ConnectionId='13' Grid.Column="1"
                                                                                      
                                             TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center"
                                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                             HorizontalAlignment="Stretch" />
                                    <Button x:ConnectionId='14' Grid.Column="2" 
                                                                                
                                            Content="&#xE8DA;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            ToolTipService.ToolTip="Browse Program"
                                            VerticalAlignment="Stretch" />
                                    <Button x:ConnectionId='15' Grid.Column="3" 
                                                                         
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                                                  
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard x:ConnectionId='16' IsClickEnabled="True"                           CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add File Launcher" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- About & Legal Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="About" />

                <controls:SettingsCard Description="Version 1.0.0"
                                       Header="BlendHub"
                                       HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/logo.png}">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <HyperlinkButton x:ConnectionId='7'                             Padding="10,6" FontSize="13" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE946;" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="Privacy Policy" VerticalAlignment="Center" />
                                </StackPanel>
                            </HyperlinkButton>
                            <HyperlinkButton x:ConnectionId='8'                              Padding="10,6" FontSize="13" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="Terms of Service" VerticalAlignment="Center" />
                                </StackPanel>
                            </HyperlinkButton>
                            <HyperlinkButton NavigateUri="https://github.com/DesignLipsx/blendhub" Padding="10,6" FontSize="13" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="GitHub Repository" VerticalAlignment="Center" />
                                </StackPanel>
                            </HyperlinkButton>
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>
                </StackPanel>
            </Border>
        </ScrollView>
    </Grid>
</Page>

