<UserControl
    x:Class="BlendHub.Pages.CreateProjectDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:services="using:BlendHub.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinWidth="500" MaxWidth="600" Padding="0">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel Spacing="20">
                
                <!-- Project Details Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                    CornerRadius="6" 
                                    Width="32" 
                                    Height="32">
                                <FontIcon Glyph="&#xE70F;" 
                                          FontSize="16" 
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Project Details" 
                                       FontWeight="SemiBold" 
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Project Name -->
                        <TextBox x:Name="ProjectNameTextBox" 
                                 Header="Project Name" 
                                 PlaceholderText="Enter project name..." 
                                 TextChanged="Validation_Changed" />
                        
                        <!-- File Name -->
                        <TextBox x:Name="FileNameTextBox" 
                                 Header="Blender File Name" 
                                 PlaceholderText="e.g., Main_Scene" 
                                 TextChanged="Validation_Changed" />
                        
                        <!-- Blender Version -->
                        <ComboBox x:Name="BlenderVersionComboBox" 
                                  Header="Blender Version" 
                                  PlaceholderText="Select installed version..." 
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="Validation_Changed">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="services:BlenderVersionInfo">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7F4;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <!-- Project Location -->
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                            <TextBox x:Name="ProjectLocationTextBox" 
                                     Header="Project Location" 
                                     PlaceholderText="Choose where to save your project..." 
                                     TextChanged="Validation_Changed" />
                            <Button Click="BrowseLocation_Click" 
                                    VerticalAlignment="Bottom"
                                    Height="32"
                                    Grid.Column="1"
                                    ToolTipService.ToolTip="Browse Folder">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xED25;" FontSize="14" />
                                    <TextBlock Text="Browse" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Folder Structure Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" 
                                    CornerRadius="6" 
                                    Width="32" 
                                    Height="32">
                                <FontIcon Glyph="&#xED25;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Folder Structure" 
                                       FontWeight="SemiBold" 
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="These folders will be created in your project directory." 
                                   FontSize="12" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <ItemsControl x:Name="FolderNamesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ProjectFolder">
                                    <Grid Margin="0,4" ColumnDefinitions="Auto, *, Auto">
                                        <TextBlock Text="{x:Bind Label}" 
                                                   VerticalAlignment="Center" 
                                                   Width="70" 
                                                   Margin="0,0,8,0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   FontSize="12"/>
                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 VerticalAlignment="Center" 
                                                 Grid.Column="1"
                                                 PlaceholderText="Folder name" />
                                        <Button x:Name="DeleteButton"
                                                Click="DeleteFolder_Click" 
                                                Grid.Column="2" 
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SubtleButtonStyle}"
                                                ToolTipService.ToolTip="Remove folder">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Click="AddFolder_Click" 
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Add Custom Folder" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- File Launchers Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" 
                                    CornerRadius="6" 
                                    Width="32" 
                                    Height="32">
                                <FontIcon Glyph="&#xE7AC;" 
                                          FontSize="16"
                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="File Launchers" 
                                       FontWeight="SemiBold" 
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Associate file extensions with applications to open them directly from the project." 
                                   FontSize="12" 
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <ItemsControl x:Name="FileLaunchersItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:FileLauncher">
                                    <Grid Margin="0,6" ColumnDefinitions="100, *, Auto, Auto">
                                        <TextBox Text="{Binding Extension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 PlaceholderText=".ext" 
                                                 VerticalAlignment="Center" 
                                                 Grid.Column="0" 
                                                 Margin="0,0,8,0" />
                                        <TextBox Text="{Binding ProgramPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 PlaceholderText="Program path..." 
                                                 IsReadOnly="True"
                                                 VerticalAlignment="Center" 
                                                 Grid.Column="1" />
                                        <Button Click="BrowseLauncher_Click" 
                                                Grid.Column="2" 
                                                Margin="4,0,0,0"
                                                ToolTipService.ToolTip="Browse Program"
                                                Style="{StaticResource SubtleButtonStyle}">
                                            <FontIcon Glyph="&#xED25;" FontSize="14" />
                                        </Button>
                                        <Button Click="DeleteLauncher_Click" 
                                                Grid.Column="3" 
                                                Margin="4,0,0,0"
                                                ToolTipService.ToolTip="Remove launcher"
                                                Style="{StaticResource SubtleButtonStyle}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Click="AddLauncher_Click" 
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource DefaultButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Add File Launcher" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Validation Warning -->
                <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="False" Severity="Warning" Title="Missing Information" Message="" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
