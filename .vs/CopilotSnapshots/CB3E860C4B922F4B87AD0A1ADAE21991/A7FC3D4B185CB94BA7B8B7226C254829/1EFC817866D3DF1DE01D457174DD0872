<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlendHub.Views.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
            <TextBlock Text="Backup" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Create backups of your Blender settings and configurations" Opacity="0.7" />
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20">
                <!-- Backup Directory Selection -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Backup Directory" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox 
                            x:Name="BackupPathTextBox"
                            Grid.Column="0"
                            PlaceholderText="Select backup directory..."
                            IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse" Click="OnBrowseBackupPath" />
                    </Grid>
                </StackPanel>

                <!-- Items to Backup -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Select Items to Backup" FontSize="14" FontWeight="SemiBold" />
                    
                    <ItemsControl x:Name="BackupItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="12" BorderThickness="1,0,0,1" 
                                      BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Path}" FontSize="12" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding SizeDisplay}" 
                                               FontSize="12" Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Total Size -->
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Total Backup Size" FontSize="12" Opacity="0.7" />
                            <TextBlock x:Name="TotalSizeTextBlock" Text="0 MB" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Selected Items" FontSize="12" Opacity="0.7" />
                            <TextBlock x:Name="SelectedItemsTextBlock" Text="0" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Backup Button -->
                <Button 
                    x:Name="BackupButton"
                    Content="Create Backup"
                    Height="48"
                    FontSize="16"
                    Click="OnBackupClick"
                    Style="{ThemeResource AccentButtonStyle}" />

                <!-- Progress -->
                <StackPanel x:Name="ProgressStackPanel" Visibility="Collapsed" Spacing="8">
                    <ProgressBar x:Name="BackupProgressBar" IsIndeterminate="False" Height="4" />
                    <TextBlock x:Name="ProgressTextBlock" Text="Backing up..." FontSize="12" />
                </StackPanel>

                <!-- Status Message -->
                <TextBlock 
                    x:Name="StatusTextBlock"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
