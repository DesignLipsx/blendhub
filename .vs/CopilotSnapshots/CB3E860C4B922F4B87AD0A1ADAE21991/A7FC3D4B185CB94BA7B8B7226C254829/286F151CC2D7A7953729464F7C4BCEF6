<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlendHub.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <StackPanel Spacing="20">
            <TextBlock Text="Welcome to BlendHub" FontSize="32" FontWeight="Bold" />
            <TextBlock Text="Your Blender settings management tool" FontSize="16" Opacity="0.7" />
            
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="16" RowSpacing="16" Margin="0,40,0,0">
                <!-- Backup Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" BorderThickness="1" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="🔒 Backup" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Create backups of your Blender settings and configurations" 
                                   TextWrapping="Wrap" Opacity="0.7" />
                        <Button Content="Go to Backup" Click="OnGoToBackup" />
                    </StackPanel>
                </Border>

                <!-- Restore Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" BorderThickness="1" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="📥 Restore" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Restore your Blender settings from a previous backup" 
                                   TextWrapping="Wrap" Opacity="0.7" />
                        <Button Content="Go to Restore" Click="OnGoToRestore" />
                    </StackPanel>
                </Border>

                <!-- Sync Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" BorderThickness="1" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="🔄 Sync" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Synchronize settings between different Blender versions" 
                                   TextWrapping="Wrap" Opacity="0.7" />
                        <Button Content="Go to Sync" Click="OnGoToSync" />
                    </StackPanel>
                </Border>

                <!-- Project Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" BorderThickness="1" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="📋 Project" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Manage your Blender projects" 
                                   TextWrapping="Wrap" Opacity="0.7" />
                        <Button Content="Go to Project" Click="OnGoToProject" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
