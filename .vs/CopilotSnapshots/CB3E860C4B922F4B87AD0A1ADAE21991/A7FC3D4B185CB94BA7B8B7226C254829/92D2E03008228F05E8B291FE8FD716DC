<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlendHub.Views.RestorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
            <TextBlock Text="Restore" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Restore your Blender settings from a previous backup" Opacity="0.7" />
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20">
                <!-- Restore Directory Selection -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Backup Directory" FontSize="14" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox 
                            x:Name="RestorePathTextBox"
                            Grid.Column="0"
                            PlaceholderText="Select backup directory..."
                            IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse" Click="OnBrowseRestorePath" />
                    </Grid>
                </StackPanel>

                <!-- Available Backups -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Available Backups" FontSize="14" FontWeight="SemiBold" />
                    
                    <ListBox x:Name="BackupListBox" MinHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" BorderThickness="0,0,0,1" 
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CreatedDate, StringFormat='Created: {0:yyyy-MM-dd HH:mm:ss}'}" 
                                                       FontSize="12" Opacity="0.6" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding SizeDisplay}" 
                                                   FontSize="12" Opacity="0.7" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Items to Restore -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Select Items to Restore" FontSize="14" FontWeight="SemiBold" />
                    
                    <ItemsControl x:Name="RestoreItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="12" BorderThickness="1,0,0,1" 
                                      BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding SizeDisplay}" 
                                               FontSize="12" Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Warning Message -->
                <Border Background="{ThemeResource SystemFillColorCautionBrush}" 
                        CornerRadius="8" Padding="12">
                    <TextBlock Text="⚠️ Restoring will overwrite your current Blender settings. This action cannot be undone." 
                               TextWrapping="Wrap" />
                </Border>

                <!-- Restore Button -->
                <Button 
                    x:Name="RestoreButton"
                    Content="Restore from Backup"
                    Height="48"
                    FontSize="16"
                    Click="OnRestoreClick"
                    Style="{ThemeResource AccentButtonStyle}" />

                <!-- Progress -->
                <StackPanel x:Name="ProgressStackPanel" Visibility="Collapsed" Spacing="8">
                    <ProgressBar x:Name="RestoreProgressBar" IsIndeterminate="False" Height="4" />
                    <TextBlock x:Name="ProgressTextBlock" Text="Restoring..." FontSize="12" />
                </StackPanel>

                <!-- Status Message -->
                <TextBlock 
                    x:Name="StatusTextBlock"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
