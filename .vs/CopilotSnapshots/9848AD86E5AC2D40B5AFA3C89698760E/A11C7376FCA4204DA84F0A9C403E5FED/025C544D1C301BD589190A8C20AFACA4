        private async void EditProject_Click(object sender, RoutedEventArgs e)
        {
            if (_project == null) return;

            var content = new EditProjectDialogContent(_project);
            ContentDialog dialog = new ContentDialog
            {
                XamlRoot = this.XamlRoot,
                Style = Application.Current.Resources["DefaultContentDialogStyle"] as Style,
                Title = $"Edit: {_project.Name}",
                PrimaryButtonText = "Save Changes",
                CloseButtonText = "Cancel",
                DefaultButton = ContentDialogButton.Primary,
                Content = content
            };

            var result = await dialog.ShowAsync();
            if (result == ContentDialogResult.Primary)
            {
                try
                {
                    ApplyProjectEdits(_project, content);
                    SaveProjectsToJson();
                    LoadProjectDetails();
                }
                catch (Exception ex)
                {
                    ContentDialog errorDialog = new ContentDialog
                    {
                        XamlRoot = this.XamlRoot,
                        Title = "Error Saving Changes",
                        Content = $"Could not save changes: {ex.Message}",
                        CloseButtonText = "OK"
                    };
                    await errorDialog.ShowAsync();
                }
            }
        }

        private void ApplyProjectEdits(Project project, EditProjectDialogContent content)
        {
            var originalNames = content.OriginalFolderNames;
            var newFolderNames = content.Folders.Select(f => f.Name).ToList();

            for (int i = 0; i < Math.Min(originalNames.Count, newFolderNames.Count); i++)
            {
                if (originalNames[i] != newFolderNames[i] &&
                    !string.IsNullOrWhiteSpace(originalNames[i]) &&
                    !string.IsNullOrWhiteSpace(newFolderNames[i]))
                {
                    string oldPath = System.IO.Path.Combine(project.Path, originalNames[i]);
                    string newPath = System.IO.Path.Combine(project.Path, newFolderNames[i]);
                    if (Directory.Exists(oldPath) && !Directory.Exists(newPath))
                        Directory.Move(oldPath, newPath);
                }
            }

            foreach (var oldName in originalNames)
            {
                if (!string.IsNullOrWhiteSpace(oldName) && !newFolderNames.Contains(oldName))
                {
                    string folderPath = System.IO.Path.Combine(project.Path, oldName);
                    if (Directory.Exists(folderPath)) Directory.Delete(folderPath, true);
                }
            }

            foreach (var name in newFolderNames)
            {
                if (!string.IsNullOrWhiteSpace(name))
                {
                    string folderPath = System.IO.Path.Combine(project.Path, name);
                    if (!Directory.Exists(folderPath)) Directory.CreateDirectory(folderPath);
                }
            }

            project.Subfolders = newFolderNames.Where(n => !string.IsNullOrWhiteSpace(n)).ToList();

            var launchers = new Dictionary<string, string>();
            foreach (var launcher in content.Launchers)
            {
                if (!string.IsNullOrWhiteSpace(launcher.Extension) && !string.IsNullOrWhiteSpace(launcher.ProgramPath))
                {
                    string ext = launcher.Extension.StartsWith(".") ? launcher.Extension : "." + launcher.Extension;
                    launchers[ext.ToLowerInvariant()] = launcher.ProgramPath;
                }
            }
            project.FileLaunchers = launchers;
        }

        private void SaveProjectsToJson()
        {
            try
            {
                string projectsFilePath = System.IO.Path.Combine(
                    Windows.Storage.ApplicationData.Current.LocalFolder.Path, "projects.json");

                List<Project> allProjects = new List<Project>();
                if (File.Exists(projectsFilePath))
                {
                    string existingJson = File.ReadAllText(projectsFilePath);
                    var existing = JsonSerializer.Deserialize<List<Project>>(existingJson);
                    if (existing != null) allProjects = existing;
                }

                var idx = allProjects.FindIndex(p => p.Name == _project?.Name && p.Path == _project?.Path);
                if (idx >= 0 && _project != null)
                    allProjects[idx] = _project;

                string json = JsonSerializer.Serialize(allProjects, new JsonSerializerOptions { WriteIndented = true });
                File.WriteAllText(projectsFilePath, json);
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Error saving projects: {ex.Message}");
            }
        }

        private void OpenSubfolder_Click(object sender, RoutedEventArgs e)
        {
            if (_project == null) return;
            if (sender is Button btn && btn.Tag is string folderName)
            {
                string path = System.IO.Path.Combine(_project.Path, folderName);
                try { if (Directory.Exists(path)) Process.Start("explorer.exe", path); }
                catch (Exception ex) { Debug.WriteLine($"Error: {ex.Message}"); }
            }
        }

        private void OpenPath(string path)
        {
            try
            {
                if (File.Exists(path))
                    Process.Start(new ProcessStartInfo { FileName = path, UseShellExecute = true });
            }
            catch (Exception ex) { Debug.WriteLine($"Error: {ex.Message}"); }
        }
    }
