        private void OpenLauncherFile_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button btn && btn.Tag is string tag)
            {
                var parts = tag.Split('|', 2);
                if (parts.Length == 2)
                {
                    string filePath = parts[0];
                    string programPath = parts[1];

                    try
                    {
                        if (!string.IsNullOrEmpty(programPath) && File.Exists(programPath))
                        {
                            Process.Start(new ProcessStartInfo
                            {
                                FileName = programPath,
                                Arguments = $"\"{filePath}\"",
                                UseShellExecute = false
                            });
                        }
                        else
                        {
                            Process.Start(new ProcessStartInfo
                            {
                                FileName = filePath,
                                UseShellExecute = true
                            });
                        }
                    }
                    catch (Exception ex)
                    {
                        Debug.WriteLine($"Error opening file: {ex.Message}");
                    }
                }
            }
        }

        private async void AddCustomFile_Click(object sender, RoutedEventArgs e)
        {
            if (_project == null) return;

            var picker = new FileOpenPicker();
            picker.SuggestedStartLocation = PickerLocationId.ComputerFolder;
            picker.FileTypeFilter.Add("*");

            var window = App.MainWindow;
            if (window != null)
            {
                IntPtr hwnd = WindowNative.GetWindowHandle(window);
                InitializeWithWindow.Initialize(picker, hwnd);
            }

            var files = await picker.PickMultipleFilesAsync();
            if (files != null && files.Count > 0)
            {
                foreach (var file in files)
                {
                    // Only allow files inside the project folder
                    if (file.Path.StartsWith(_project.Path, StringComparison.OrdinalIgnoreCase))
                    {
                        string relativePath = System.IO.Path.GetRelativePath(_project.Path, file.Path);
                        if (!_project.CustomFiles.Contains(relativePath, StringComparer.OrdinalIgnoreCase))
                        {
                            _project.CustomFiles.Add(relativePath);
                        }
                    }
                    else
                    {
                        // File outside project folder — copy to project root and add
                        string destPath = System.IO.Path.Combine(_project.Path, file.Name);
                        try
                        {
                            if (!File.Exists(destPath))
                            {
                                File.Copy(file.Path, destPath);
                            }
                            string rel = file.Name;
                            if (!_project.CustomFiles.Contains(rel, StringComparer.OrdinalIgnoreCase))
                            {
                                _project.CustomFiles.Add(rel);
                            }
                        }
                        catch (Exception ex)
                        {
                            Debug.WriteLine($"Error copying file: {ex.Message}");
                        }
                    }
                }

                SaveProjectsToJson();
                LoadProjectDetails();
            }
        }

        private void RemoveCustomFile_Click(object sender, RoutedEventArgs e)
        {
            if (_project == null) return;
            if (sender is Button btn && btn.Tag is string relativePath)
            {
                _project.CustomFiles.Remove(relativePath);
                SaveProjectsToJson();
                LoadProjectDetails();
            }
        }

