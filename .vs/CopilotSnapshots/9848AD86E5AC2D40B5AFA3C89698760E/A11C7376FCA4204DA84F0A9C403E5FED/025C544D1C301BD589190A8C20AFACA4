        private async void DeleteProject_Click(object sender, RoutedEventArgs e)
        {
            if (_project == null) return;

            var confirmDialog = new ContentDialog
            {
                Title = "Delete Project?",
                Content = $"Are you sure you want to delete '{_project.Name}'? This will remove the project from your list and delete all associated files.",
                PrimaryButtonText = "Delete",
                CloseButtonText = "Cancel",
                DefaultButton = ContentDialogButton.Close,
                PrimaryButtonStyle = Application.Current.Resources["DangerButtonStyle"] as Style,
                XamlRoot = this.XamlRoot
            };

            var result = await confirmDialog.ShowAsync();
            if (result == ContentDialogResult.Primary)
            {
                try
                {
                    // Delete project files if they exist
                    if (Directory.Exists(_project.Path))
                    {
                        Directory.Delete(_project.Path, true);
                    }

                    // Remove from projects.json
                    string projectsFilePath = System.IO.Path.Combine(
                        Windows.Storage.ApplicationData.Current.LocalFolder.Path, "projects.json");
                    if (File.Exists(projectsFilePath))
                    {
                        string existingJson = File.ReadAllText(projectsFilePath);
                        var allProjects = JsonSerializer.Deserialize<List<Project>>(existingJson) ?? new List<Project>();
                        allProjects.RemoveAll(p => p.Name == _project.Name && p.Path == _project.Path);
                        string json = JsonSerializer.Serialize(allProjects, new JsonSerializerOptions { WriteIndented = true });
                        File.WriteAllText(projectsFilePath, json);
                    }

                    // Navigate back to project list
                    if (Frame.CanGoBack)
                    {
                        Frame.GoBack();
                    }
                }
                catch (Exception ex)
                {
                    ContentDialog errorDialog = new ContentDialog
                    {
                        XamlRoot = this.XamlRoot,
                        Title = "Error Deleting Project",
                        Content = $"Could not delete project: {ex.Message}",
                        CloseButtonText = "OK"
                    };
                    await errorDialog.ShowAsync();
                }
            }
        }

