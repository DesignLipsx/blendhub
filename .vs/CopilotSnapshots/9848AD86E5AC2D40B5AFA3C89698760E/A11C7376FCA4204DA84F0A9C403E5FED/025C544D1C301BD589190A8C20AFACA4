        private Project? _project;

        public ProjectDetailPage()
        {
            this.InitializeComponent();
        }

        protected override void OnNavigatedTo(NavigationEventArgs e)
        {
            base.OnNavigatedTo(e);
            if (e.Parameter is Project project)
            {
                _project = project;
                LoadProjectDetails();
            }
        }

        private void LoadProjectDetails()
        {
            if (_project == null) return;

            ProjectTitle.Text = _project.Name;
            ProjectPath.Text = _project.Path;
            BlenderVersionText.Text = _project.BlenderVersion;
            BlendFileText.Text = _project.BlendFileName;
            CreatedAtText.Text = _project.CreatedAt.ToString("f");

            bool folderExists = _project.FolderExists;
            bool blendExists = _project.BlendFileExists;

            if (folderExists && blendExists)
            {
                StatusText.Text = "✅ Ready";
                StatusText.Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Microsoft.UI.Colors.Green);
            }
            else if (folderExists && !blendExists)
            {
                StatusText.Text = "⚠ .blend file missing";
                StatusText.Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Microsoft.UI.Colors.Orange);
            }
            else
            {
                StatusText.Text = "❌ Project folder not found";
                StatusText.Foreground = new Microsoft.UI.Xaml.Media.SolidColorBrush(Microsoft.UI.Colors.Red);
            }

            MissingProjectInfoBar.IsOpen = !folderExists;
            OpenBlendBtn.IsEnabled = blendExists;
            OpenFolderBtn.IsEnabled = folderExists;
            EditBtn.IsEnabled = folderExists;
            AddFileBtn.IsEnabled = folderExists;

            // Subfolders
            if (_project.Subfolders.Count > 0)
            {
                SubfoldersListControl.ItemsSource = _project.Subfolders;
                NoSubfoldersText.Visibility = Visibility.Collapsed;
            }
            else
            {
                NoSubfoldersText.Visibility = Visibility.Visible;
            }

            // Project files
            LoadProjectFiles();
        }

        private async System.Threading.Tasks.Task LoadExeIconAsync(string exePath, Image target)
        {
            try
            {
                if (!File.Exists(exePath)) return;
                var storageFile = await Windows.Storage.StorageFile.GetFileFromPathAsync(exePath);
                var thumbnail = await storageFile.GetThumbnailAsync(ThumbnailMode.SingleItem, 32);
                if (thumbnail != null)
                {
                    var bitmapImage = new BitmapImage();
                    await bitmapImage.SetSourceAsync(thumbnail.AsStreamForRead().AsRandomAccessStream());
                    target.Source = bitmapImage;
                }
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"Could not load icon for {exePath}: {ex.Message}");
            }
        }

        private void LoadProjectFiles()
        {
            // Clear previous dynamic entries (keep NoFilesText at the end)
            while (ProjectFilesPanel.Children.Count > 1)
            {
                ProjectFilesPanel.Children.RemoveAt(0);
            }

            if (_project == null || !_project.FolderExists)
            {
                NoFilesText.Visibility = Visibility.Visible;
                return;
            }

            int insertIndex = 0;
            bool hasFiles = false;

            // 1. Auto-detected files from launchers
            if (_project.FileLaunchers.Count > 0)
            {
                var launcherExts = new HashSet<string>(_project.FileLaunchers.Keys, StringComparer.OrdinalIgnoreCase);
                var matchingFiles = new List<FileInfo>();

                try
                {
                    var dirInfo = new DirectoryInfo(_project.Path);
                    var allFiles = dirInfo.GetFiles("*.*", SearchOption.AllDirectories);
                    foreach (var file in allFiles)
                    {
                        if (launcherExts.Contains(file.Extension.ToLowerInvariant()))
                        {
                            matchingFiles.Add(file);
                        }
                    }
                }
                catch (Exception ex)
                {
                    Debug.WriteLine($"Error scanning files: {ex.Message}");
                }

                if (matchingFiles.Count > 0)
                {
                    hasFiles = true;
                    var grouped = matchingFiles.GroupBy(f => f.Extension.ToLowerInvariant()).OrderBy(g => g.Key);

                    foreach (var group in grouped)
                    {
                        string ext = group.Key;
                        string programPath = _project.FileLaunchers.ContainsKey(ext) ? _project.FileLaunchers[ext] : "";
                        string programName = string.IsNullOrEmpty(programPath) ? "Default" : System.IO.Path.GetFileNameWithoutExtension(programPath);

                        // Section header with exe icon
                        var headerPanel = new StackPanel
                        {
                            Orientation = Orientation.Horizontal,
                            Spacing = 8,
                            Margin = new Thickness(0, insertIndex > 0 ? 12 : 0, 0, 6)
                        };

                        var headerIcon = new Image
                        {
                            Width = 18, Height = 18,
                            Stretch = Microsoft.UI.Xaml.Media.Stretch.Uniform,
                            VerticalAlignment = VerticalAlignment.Center
                        };
                        _ = LoadExeIconAsync(programPath, headerIcon);
                        headerPanel.Children.Add(headerIcon);
                        headerPanel.Children.Add(new TextBlock
                        {
                            Text = $"{ext.ToUpperInvariant()} Files — {programName}",
                            FontWeight = Microsoft.UI.Text.FontWeights.SemiBold,
                            FontSize = 14,
                            VerticalAlignment = VerticalAlignment.Center
                        });

                        ProjectFilesPanel.Children.Insert(insertIndex++, headerPanel);

                        foreach (var file in group)
                        {
                            insertIndex = AddFileRow(insertIndex, file.Name,
                                System.IO.Path.GetDirectoryName(System.IO.Path.GetRelativePath(_project.Path, file.FullName)) ?? "",
                                file.FullName, programPath, programName, false);
                        }
                    }
                }
            }

            // 2. Custom files (manually added)
            if (_project.CustomFiles.Count > 0)
            {
                var validCustomFiles = new List<string>();
                foreach (var relPath in _project.CustomFiles)
                {
                    string fullPath = System.IO.Path.Combine(_project.Path, relPath);
                    if (File.Exists(fullPath))
                    {
                        validCustomFiles.Add(relPath);
                    }
                }

                if (validCustomFiles.Count > 0)
                {
                    hasFiles = true;

                    var headerPanel = new StackPanel
                    {
                        Orientation = Orientation.Horizontal,
                        Spacing = 8,
                        Margin = new Thickness(0, insertIndex > 0 ? 12 : 0, 0, 6)
                    };
                    headerPanel.Children.Add(new FontIcon
                    {
                        Glyph = "\uE8A5",
                        FontSize = 16,
                        VerticalAlignment = VerticalAlignment.Center
                    });
                    headerPanel.Children.Add(new TextBlock
                    {
                        Text = "Custom Files — System Default",
                        FontWeight = Microsoft.UI.Text.FontWeights.SemiBold,
                        FontSize = 14,
                        VerticalAlignment = VerticalAlignment.Center
                    });
                    ProjectFilesPanel.Children.Insert(insertIndex++, headerPanel);

                    foreach (var relPath in validCustomFiles)
                    {
                        string fullPath = System.IO.Path.Combine(_project.Path, relPath);
                        string fileName = System.IO.Path.GetFileName(relPath);
                        string subfolder = System.IO.Path.GetDirectoryName(relPath) ?? "";

                        insertIndex = AddCustomFileRow(insertIndex, fileName, subfolder, fullPath, relPath);
                    }
                }
            }

            NoFilesText.Visibility = hasFiles ? Visibility.Collapsed : Visibility.Visible;
        }

