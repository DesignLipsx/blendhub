<Page
    x:Class="BlendHub.Views.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                <Button Click="BackButton_Click" 
                        Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" />
                </Button>
                <StackPanel Spacing="4">
                    <TextBlock x:Name="ProjectTitle" Text="" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="ProjectPath" Text="" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="EditBtn" Click="EditProject_Click" ToolTipService.ToolTip="Edit Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                        <TextBlock Text="Edit" />
                    </StackPanel>
                </Button>
                <Button x:Name="DeleteBtn" Click="DeleteProject_Click" ToolTipService.ToolTip="Delete Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        <TextBlock Text="Delete" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenFolderBtn" Click="OpenFolder_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xED25;" FontSize="14" />
                        <TextBlock Text="Open Folder" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenBlendBtn" Click="OpenBlend_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="Open .blend" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24">
                <!-- Warning -->
                <InfoBar x:Name="MissingProjectInfoBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Project Folder Missing"
                         Message="The project folder could not be found on disk. Some actions may not work." />

                <!-- Quick Stats Row -->
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Blender Version Card -->
                    <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Blender Version" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="BlenderVersionText" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <!-- Blend File Card -->
                    <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Blend File" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="BlendFileText" FontSize="14" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <!-- Created Date Card -->
                    <Border Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Created" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="CreatedAtText" FontSize="14" />
                        </StackPanel>
                    </Border>

                    <!-- Status Card -->
                    <Border Grid.Column="3" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="StatusText" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Notes Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Notes" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Add project notes, reminders, or tasks." 
                               FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="0">
                        <TextBox x:Name="NotesTextBox" 
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="12"
                                 PlaceholderText="e.g., Improve lighting, add animations, fix render settings..."
                                 TextChanged="NotesTextBox_TextChanged" />
                    </Border>
                </StackPanel>

                <!-- Content Grid: Subfolders + Project Files -->
                <Grid ColumnSpacing="20" RowSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Subfolders -->
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Subfolders" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Quick access to project directories." 
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="12" MinHeight="180">
                            <StackPanel>
                                <ItemsControl x:Name="SubfoldersListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Margin="0,4" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                                <FontIcon Glyph="&#xED25;" FontSize="14" VerticalAlignment="Center"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind}" Grid.Column="1" VerticalAlignment="Center" FontSize="13" />
                                                <Button Grid.Column="2" Click="OpenSubfolder_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Open folder" Style="{StaticResource SubtleButtonStyle}"
                                                        Padding="4">
                                                    <FontIcon Glyph="&#xE8DA;" FontSize="12" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid x:Name="NoSubfoldersContainer" Visibility="Collapsed" 
                                      Height="150" RowDefinitions="*, Auto, *">
                                    <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xED25;" FontSize="32" HorizontalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="No subfolders" HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" 
                                                   FontSize="13" FontWeight="Medium" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: Project Files -->
                    <StackPanel Grid.Column="1" Spacing="8">
                        <Grid>
                            <TextBlock Text="Project Files" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button x:Name="AddFileBtn" Click="AddCustomFile_Click" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                                    <TextBlock Text="Add File" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="Auto-detected and manually-added files." 
                                   FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="12" MinHeight="180">
                            <StackPanel x:Name="ProjectFilesPanel">
                                <Grid x:Name="NoFilesContainer" Visibility="Collapsed" 
                                      Height="150" RowDefinitions="*, Auto, *">
                                    <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C3;" FontSize="32" HorizontalAlignment="Center"
                                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="No project files" HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" 
                                                   FontSize="13" FontWeight="Medium" />
                                        <TextBlock Text="Click 'Add File' to add custom files" HorizontalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" 
                                                   FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
