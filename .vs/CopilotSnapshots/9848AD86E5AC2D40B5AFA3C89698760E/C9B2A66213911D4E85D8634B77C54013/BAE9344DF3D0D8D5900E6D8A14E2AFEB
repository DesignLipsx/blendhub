<Page
    x:Class="BlendHub.Views.ProjectDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                <Button Click="BackButton_Click" 
                        Style="{StaticResource SubtleButtonStyle}"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" />
                </Button>
                <StackPanel Spacing="2">
                    <TextBlock x:Name="ProjectTitle" Text="" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="ProjectPath" Text="" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="EditBtn" Click="EditProject_Click" ToolTipService.ToolTip="Edit Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                        <TextBlock Text="Edit" />
                    </StackPanel>
                </Button>
                <Button x:Name="DeleteBtn" Click="DeleteProject_Click" ToolTipService.ToolTip="Delete Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        <TextBlock Text="Delete" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenFolderBtn" Click="OpenFolder_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xED25;" FontSize="14" />
                        <TextBlock Text="Open Folder" />
                    </StackPanel>
                </Button>
                <Button x:Name="OpenBlendBtn" Click="OpenBlend_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="Open .blend" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                <!-- Warning -->
                <InfoBar x:Name="MissingProjectInfoBar"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Warning"
                         Title="Project Folder Missing"
                         Message="The project folder could not be found on disk. Some actions may not work." />

                <!-- Two Column: Details + Subfolders -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Project Details -->
                    <StackPanel Grid.Column="0" Spacing="12">
                        <TextBlock Text="Project Details" FontSize="18" FontWeight="Medium" />
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="20">
                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="20" RowSpacing="10">
                                <TextBlock Text="Blender Version:" FontWeight="Medium" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBlock x:Name="BlenderVersionText" Grid.Row="0" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                                <TextBlock Text="Blend File:" FontWeight="Medium" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBlock x:Name="BlendFileText" Grid.Row="1" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                                <TextBlock Text="Created:" FontWeight="Medium" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBlock x:Name="CreatedAtText" Grid.Row="2" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />

                                <TextBlock Text="Status:" FontWeight="Medium" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatusText" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Right: Subfolders -->
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock Text="Subfolders" FontSize="18" FontWeight="Medium" />
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <ItemsControl x:Name="SubfoldersListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Grid Margin="0,3" ColumnDefinitions="Auto, *, Auto">
                                                <FontIcon Glyph="&#xED25;" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"
                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind}" Grid.Column="1" VerticalAlignment="Center" FontSize="14" />
                                                <Button Grid.Column="2" Click="OpenSubfolder_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Open folder" Style="{StaticResource SubtleButtonStyle}">
                                                    <FontIcon Glyph="&#xE8DA;" FontSize="12" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoSubfoldersText" Text="No subfolders." 
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Project Files (full width) -->
                <StackPanel Spacing="12">
                    <Grid>
                        <TextBlock Text="Project Files" FontSize="18" FontWeight="Medium" VerticalAlignment="Center" />
                        <Button x:Name="AddFileBtn" Click="AddCustomFile_Click" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="12" />
                                <TextBlock Text="Add File" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <TextBlock Text="Auto-detected launcher files and manually-added project files." 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" />
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel x:Name="ProjectFilesPanel">
                            <TextBlock x:Name="NoFilesText" Text="No project files found. Click 'Add File' to add custom files." 
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
