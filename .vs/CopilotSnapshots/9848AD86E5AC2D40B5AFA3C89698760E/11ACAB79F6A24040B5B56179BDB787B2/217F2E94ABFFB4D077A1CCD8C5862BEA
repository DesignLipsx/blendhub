<Page
    x:Class="BlendHub.Views.ProjectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Views"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="36,24,36,36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Spacing="8">
                <TextBlock Text="Project Management" FontSize="32" FontWeight="SemiBold" />
                <TextBlock Text="Setup and organize your Blender project structures efficiently." FontSize="18" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Button x:Name="CreateProjectBtn" 
                    Content="Create Project" 
                    Click="ShowDialog_Click" 
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="24,10" 
                    FontSize="14" 
                    FontWeight="Normal"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Progress Bar -->
        <StackPanel x:Name="CreatingProgressPanel" Grid.Row="1" Visibility="Collapsed" 
                    Orientation="Horizontal" Spacing="12" Margin="0,0,0,16" VerticalAlignment="Center">
            <ProgressBar Width="130" IsIndeterminate="True" ShowPaused="False" ShowError="False" />
            <TextBlock x:Name="ProgressText" Text="Creating project..." VerticalAlignment="Center" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Feedback -->
        <InfoBar x:Name="ProjectSuccessInfoBar"
                 Grid.Row="2"
                 IsOpen="False"
                 Severity="Success"
                 Title="Project Created"
                 Margin="0,0,0,16">
            <InfoBar.ActionButton>
                <Button Content="Open Project" Click="OpenProject_Click" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- Projects List -->
        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Stretch">
            <StackPanel Spacing="16">
                <!-- Section Header with View Toggle -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Recent Projects" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="View" Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                   VerticalAlignment="Center" FontSize="13" />
                        
                        <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" 
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="3">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <ToggleButton x:Name="CompactViewBtn" Click="CompactView_Click" IsChecked="True"
                                              ToolTipService.ToolTip="Compact View" Width="36" Height="30" Padding="0" CornerRadius="6">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="14" />
                                </ToggleButton>
                                <ToggleButton x:Name="DetailedViewBtn" Click="DetailedView_Click" IsChecked="False"
                                              ToolTipService.ToolTip="Detailed View" Width="36" Height="30" Padding="0" CornerRadius="6">
                                    <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Compact View -->
                <ItemsControl x:Name="CompactProjectsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Project">
                            <Border Margin="0,0,0,10" 
                                    Padding="16" 
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Opacity="{x:Bind models:Project.GetOpacity(FolderExists)}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" 
                                                CornerRadius="8" 
                                                Width="48" Height="48" 
                                                Margin="0,0,16,0"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                            <Image Source="/Assets/blender_logo.png" 
                                                   Stretch="Uniform" 
                                                   Width="32" Height="32" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Path}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE925;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{x:Bind BlenderVersion}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind CreatedAt}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Click="OpenProjectCard_Click"
                                                    Tag="{x:Bind Name}"
                                                    Style="{StaticResource AccentButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8DA;" FontSize="14" />
                                                    <TextBlock Text="Open Project" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="OpenProjectDetail_Click"
                                                    Tag="{x:Bind Name}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                                                    <TextBlock Text="View Details" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock Grid.Row="1" 
                                               Text="{x:Bind StatusText}" 
                                               FontSize="12" 
                                               Foreground="#E8912D" 
                                               Margin="64,8,0,0"
                                               Visibility="{x:Bind models:Project.GetMissingVisibility(FolderExists)}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Detailed View -->
                <ItemsControl x:Name="DetailedProjectsList" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Project">
                            <Border Margin="0,0,0,16" 
                                    Padding="20" 
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Opacity="{x:Bind models:Project.GetOpacity(FolderExists)}">
                                <StackPanel Spacing="16">
                                    <!-- Top row: same as compact -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" 
                                                CornerRadius="8" 
                                                Width="48" Height="48" 
                                                Margin="0,0,16,0"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                                            <Image Source="/Assets/blender_logo.png" 
                                                   Stretch="Uniform" 
                                                   Width="32" Height="32" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Path}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE925;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{x:Bind BlenderVersion}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind CreatedAt}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Click="OpenProjectCard_Click"
                                                    Tag="{x:Bind Name}"
                                                    Style="{StaticResource AccentButtonStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8DA;" FontSize="14" />
                                                    <TextBlock Text="Open Project" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="OpenProjectDetail_Click"
                                                    Tag="{x:Bind Name}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                                                    <TextBlock Text="View Details" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{x:Bind StatusText}" 
                                               FontSize="12" 
                                               Foreground="#E8912D" 
                                               Margin="64,0,0,0"
                                               Visibility="{x:Bind models:Project.GetMissingVisibility(FolderExists)}" />

                                    <!-- Detailed: Project Files (populated dynamically) -->
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                            BorderThickness="1" CornerRadius="6" Padding="12"
                                            Margin="64,0,0,0">
                                        <StackPanel x:Name="DetailedFilesPanel" Loaded="DetailedFilesPanel_Loaded" Tag="{x:Bind Name}" Spacing="4">
                                            <TextBlock Text="Project Files" FontWeight="Medium" FontSize="13" 
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Drag and Drop Zone -->
                <Border x:Name="DropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        CornerRadius="8"
                        Padding="0"
                        Margin="0,16,0,0">
                    <Grid>
                        <!-- Dotted border using Rectangle -->
                        <Rectangle Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="2,2"
                                   RadiusX="8"
                                   RadiusY="8"
                                   Fill="Transparent"
                                   Margin="0"/>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Padding="40,32">
                            <FontIcon Glyph="&#xE8E5;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Drag and drop to add project"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Drop a folder containing .blend files here"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="BrowseProjectBtn"
                                    Click="BrowseProjectBtn_Click"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xED25;" FontSize="14"/>
                                    <TextBlock Text="Browse for project folder" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyStatePanel" Spacing="16" Margin="0,40,0,0" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7C3;" FontSize="64" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No projects yet. Create your first project by clicking 'Create Project'." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
